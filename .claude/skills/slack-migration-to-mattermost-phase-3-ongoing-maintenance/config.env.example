# Phase 3: Ongoing Mattermost Maintenance — config.env
#
# Copy this file to ./config.env (or set PHASE3_CONFIG=<path>) and fill in the
# values below. Values marked REQUIRED block ./maintain.sh from running.
# Values marked EXAMPLE are fully populated with Acme Corp defaults so you can
# see what a healthy config looks like. Replace acme.com with your real domain.
#
# Safety: NEVER commit this file to git. A default .gitignore shipped with
# this skill excludes it; if you make the working directory your own repo,
# verify the .gitignore before your first commit.

# --- Workspace & working-directory -----------------------------------------

# REQUIRED. Short name for this Mattermost deployment, used in report filenames.
# EXAMPLE: acme-mattermost
WORKSPACE_NAME=""

# Where Phase 3 writes reports. Relative to the current directory by default.
# EXAMPLE: ./workdir-phase3
PHASE3_WORKSPACE_ROOT="./workdir-phase3"

# --- Target Mattermost server ----------------------------------------------

# REQUIRED. Live Mattermost URL (must match the TLS cert).
# EXAMPLE: https://chat.acme.com
MATTERMOST_URL=""

# REQUIRED. Mattermost admin Personal Access Token. Create from
# System Console → Integrations → Personal Access Tokens → Create.
# (Enable PATs first under Plugins → Management.)
# EXAMPLE: abcdef1234567890abcdef1234567890
MATTERMOST_ADMIN_TOKEN=""

# Optional fallback if PAT fails or for first-time mmctl auth.
MATTERMOST_ADMIN_USER=""
MATTERMOST_ADMIN_PASS=""

# Team identifier for scoped checks (users in a specific team, etc.).
# EXAMPLE: acme
MATTERMOST_TEAM_NAME=""

# --- SSH to target host ----------------------------------------------------

# REQUIRED. The hostname or IP of your Mattermost server.
# EXAMPLE: chat.acme.com
TARGET_HOST=""

# REQUIRED. SSH user. Phase 2's provisioner creates a "deploy" user; use that.
# EXAMPLE: deploy
TARGET_SSH_USER="deploy"

# Optional. Path to the SSH private key if not your default.
# EXAMPLE: ~/.ssh/id_ed25519
TARGET_SSH_KEY=""

# SSH options forwarded to every ssh/scp/rsync invocation. Defaults are safe.
# EXAMPLE: -o BatchMode=yes -o ServerAliveInterval=30 -o ConnectTimeout=10
TARGET_SSH_OPTS="-o BatchMode=yes -o ServerAliveInterval=30 -o ConnectTimeout=10"

# --- PostgreSQL ------------------------------------------------------------

# REQUIRED for backup, db-health, restore-drill. Points at the live Mattermost
# DB. For local PG co-hosted with Mattermost, use the deploy-user password.
# EXAMPLE: postgres://mmuser:strongpassword@localhost:5432/mattermost?sslmode=disable
POSTGRES_DSN=""

# Whether the DSN is reachable from the operator workstation (public DSN) or
# only over SSH on TARGET_HOST. Set "ssh" for the common localhost-only case.
# EXAMPLE: ssh
POSTGRES_REACH="ssh"

# --- Backup & off-site -----------------------------------------------------

# REQUIRED. Directory on TARGET_HOST where nightly pg_dumps are written.
# EXAMPLE: /var/backups/mattermost
BACKUP_PATH="/var/backups/mattermost"

# Retention (days) for on-host dumps. Older files are rotated out.
# EXAMPLE: 30
BACKUP_RETENTION_DAILY_DAYS="30"
BACKUP_RETENTION_WEEKLY_WEEKS="12"
BACKUP_RETENTION_MONTHLY_MONTHS="12"

# Off-site destination. Use any rclone remote, or an S3/R2 bucket. If empty,
# backups stay on the target host only (NOT recommended for production).
# EXAMPLE: r2:mm-backups-acme
OFFSITE_REMOTE=""

# Optional extra rclone flags (e.g. bandwidth cap).
# EXAMPLE: --transfers 4 --bwlimit 50M
OFFSITE_RCLONE_OPTS=""

# --- Restore-drill scratch DB ---------------------------------------------

# Separate PG DSN that the quarterly restore-drill will restore INTO. Must be
# a DB you don't mind wiping. Typical pattern: same PG server, different DB.
# EXAMPLE: postgres://mmuser:strongpassword@localhost:5432/mm_restore_drill?sslmode=disable
SCRATCH_DB_URL=""

# If set, restore-drill runs a row-count sanity check against these minimum
# values. Taken from your last successful handoff.json.counts.
# EXAMPLE: 337
RESTORE_MIN_USERS="0"
# EXAMPLE: 142
RESTORE_MIN_CHANNELS="0"
# EXAMPLE: 1280000
RESTORE_MIN_POSTS="0"

# --- OS update policy ------------------------------------------------------

# "security" (default) applies only unattended-security updates.
# "all" applies every available apt upgrade.
# "none" disables os-update (not recommended).
# EXAMPLE: security
OS_UPDATE_POLICY="security"

# --- Reboot window (UTC) ---------------------------------------------------

# Day-of-week (Sun, Mon, Tue, Wed, Thu, Fri, Sat) for automated reboots.
# EXAMPLE: Sun
REBOOT_WINDOW_DAY="Sun"

# Hour range (UTC, 24-hour) for automated reboots. Inclusive start, exclusive end.
# EXAMPLE (03:00-05:00 UTC = overnight in Europe/US off-hours): 3
REBOOT_WINDOW_HOUR_START="3"
# EXAMPLE: 5
REBOOT_WINDOW_HOUR_END="5"

# If a reboot is required but the next window is more than this many hours
# away, skip this run and ask a human (block schedule-reboot).
# EXAMPLE: 168  (one week)
REBOOT_WINDOW_MAX_WAIT_HOURS="168"

# --- Mattermost upgrade policy --------------------------------------------

# Target version to upgrade to. Leave empty to pin to "latest patch of the
# current minor". Set to e.g. "10.11.3" to target a specific release.
# EXAMPLE: 10.11.3
MATTERMOST_TARGET_VERSION=""

# "auto" auto-rolls-back on upgrade failure. "manual" leaves the operator to decide.
# EXAMPLE: auto
MATTERMOST_UPGRADE_ROLLBACK="auto"

# --- Health-check thresholds ---------------------------------------------

# Disk usage (%) at which health reports red.
# EXAMPLE: 85
HEALTH_DISK_PCT_RED="85"
HEALTH_DISK_PCT_YELLOW="75"

# Postgres connection count as % of max_connections.
# EXAMPLE: 80
HEALTH_PG_CONN_PCT_RED="80"
HEALTH_PG_CONN_PCT_YELLOW="60"

# Log error rate: lines/min in /opt/mattermost/logs/mattermost.log at level=error.
# EXAMPLE: 10
HEALTH_LOG_ERR_PER_MIN_RED="10"
HEALTH_LOG_ERR_PER_MIN_YELLOW="3"

# --- Alerting (optional) --------------------------------------------------

# Webhook URL posted to when a health check comes back red. Format is a
# simple JSON POST; Slack/Mattermost/Discord incoming-webhook URLs all work.
# EXAMPLE: https://chat.acme.com/hooks/abcdef12345
ALERT_WEBHOOK_URL=""

# Email address to cc when alerting. Optional; requires SMTP from Phase 2.
# EXAMPLE: ops@acme.com
ALERT_EMAIL=""

# --- Rollback owner -------------------------------------------------------

# Named human responsible for calling a go/no-go on upgrades and DR actions.
# EXAMPLE: Jane Admin <jane@acme.com>
ROLLBACK_OWNER=""
