# Phase 1 (extraction) configuration. Copy to config.env and fill in your values.
# Every "# EXAMPLE:" comment shows a realistic value for Acme Corp, a fictitious
# 340-user Business+ Slack workspace moving to chat.acme.com. Replace with yours.

# === Identity ===
WORKSPACE_NAME="acme-slack"                    # EXAMPLE: "acme-slack" — short slug used in filenames + reports
PHASE1_WORKSPACE_ROOT="./workdir"              # EXAMPLE: "./workdir" — artifact tree lives here; needs 3x export size free

MATTERMOST_TEAM_NAME="acme"                    # EXAMPLE: "acme" — lowercase, hyphens only; becomes the Mattermost team slug
MATTERMOST_TEAM_DISPLAY_NAME="Acme"            # EXAMPLE: "Acme Corp" — human-readable team name

# === Track A: official Slack admin export (Business+ / Enterprise Grid) ===
# Download the ZIP + channel-audit CSV + member CSV from Workspace Settings -> Security,
# then paste absolute paths here. Leave blank if using Track B (slackdump-primary).
SLACK_EXPORT_ZIP=""                            # EXAMPLE: "/Users/jane/Downloads/acme_slack_export_2026-04-15.zip"
SLACK_CHANNEL_AUDIT_CSV=""                     # EXAMPLE: "/Users/jane/Downloads/acme_channel_audit_2026-04-15.csv"
SLACK_MEMBER_CSV=""                            # EXAMPLE: "/Users/jane/Downloads/acme_member_list_2026-04-15.csv"

# === Track B: slackdump-primary (Pro / when official export is unavailable) ===
SLACK_TOKEN=""                                 # EXAMPLE: "xoxp-1234567890-..." — Slack app user token; needs users:read.email + files:read
SLACKDUMP_BIN="slackdump"                      # EXAMPLE: "slackdump" — override if not on PATH
SLACKDUMP_ARGS=""                              # EXAMPLE: "--time-from 2023-01-01" — extra CLI args passed through
SLACKDUMP_WITH_FILES="1"                       # EXAMPLE: "1" — always "1" unless you're debugging
SLACKDUMP_PRIMARY="0"                          # EXAMPLE: "0" for Track A, "1" for Track B

# === Enrichment + transform ===
SLACK_ADVANCED_EXPORTER_BIN="slack-advanced-exporter"
MMETL_BIN="mmetl"
MMETL_DEFAULT_EMAIL_DOMAIN=""                  # EXAMPLE: "acme.com" — if some Slack users lack email, mmetl fabricates <user>@<domain>
MMETL_EXTRA_FLAGS=""                           # EXAMPLE: "--discard-invalid-props" — use if mmetl panics on odd messages

# === Sidecars (canvases, lists, workflows, audit CSVs) ===
PHASE1_SIDECAR_INPUTS=""                       # EXAMPLE: "/Users/jane/acme/canvases,/Users/jane/acme/lists"
PHASE1_WORKFLOW_INPUTS=""                      # EXAMPLE: "/Users/jane/acme/workflows" — directory of Workflow Builder JSON files
PHASE1_KNOWN_GAPS=""                           # EXAMPLE: "huddles,audio-recap" — things you already know won't be in the export
PHASE1_SIDECAR_CHANNELS="slack-canvases-archive,slack-lists-archive,slack-export-admin"
PHASE1_EVIDENCE_PATHS=""                       # EXAMPLE: "/Users/jane/acme/screenshots" — extra evidence to include in the pack

# === Split-import (for large workspaces with many years of history) ===
SPLIT_IMPORT_YEARS=""                          # EXAMPLE: "2022,2023,2024,2025" — produces one batch ZIP per year

# === MCP wiring (used by scripts/install-mcp-servers.sh) ===
# Leave blank to skip the corresponding server. At least one of
# SLACK_BOT_TOKEN+SLACK_TEAM_ID or SLACK_MCP_TOKEN+SLACK_MCP_COOKIE is
# required to register a Slack MCP.
SLACK_BOT_TOKEN=""                             # EXAMPLE: "xoxb-..." — Anthropic Slack MCP needs this + SLACK_TEAM_ID
SLACK_TEAM_ID=""                               # EXAMPLE: "T01ABCDEFGH" — find in Slack admin -> Workspace settings
SLACK_MCP_TOKEN=""                             # EXAMPLE: "xoxc-..." — korotovsky stealth MCP (browser-session token)
SLACK_MCP_COOKIE=""                            # EXAMPLE: "xoxd-..." — browser d= cookie; pair with SLACK_MCP_TOKEN
