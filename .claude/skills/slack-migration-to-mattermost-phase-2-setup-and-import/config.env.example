# Phase 2 (deploy + import + cutover) configuration. Copy to config.env and fill in.
# Every "# EXAMPLE:" comment shows a realistic value for Acme Corp, a fictitious
# 340-user Business+ Slack workspace moving to chat.acme.com on Hetzner AX42.

# === Identity + intake from Phase 1 ===
WORKSPACE_NAME="acme-slack"                    # EXAMPLE: same slug you used in Phase 1
PHASE2_WORKSPACE_ROOT="./workdir"              # EXAMPLE: "./workdir" or "./workdir-phase2"

HANDOFF_JSON=""                                # EXAMPLE: "/Users/jane/slack-migration/acme/workdir/artifacts/reports/handoff.json"
IMPORT_ZIP=""                                  # EXAMPLE: "/Users/jane/slack-migration/acme/workdir/artifacts/import-ready/mattermost-bulk-import.zip"

# === Mattermost target ===
MATTERMOST_URL="https://chat.acme.com"         # EXAMPLE: "https://chat.acme.com" — production HTTPS URL
MATTERMOST_ADMIN_USER="admin"                  # EXAMPLE: "admin"
MATTERMOST_ADMIN_PASS=""                       # EXAMPLE: "..." — strong random password; keep in password manager
MATTERMOST_TEAM_NAME="acme"                    # EXAMPLE: "acme" — MUST match Phase 1's team name
MATTERMOST_SERVICE_NAME="mattermost"
MATTERMOST_CONFIG_PATH="/opt/mattermost/config/config.json"
MATTERMOST_DATA_PATH="/opt/mattermost/data"
MATTERMOST_LISTEN_ADDRESS="127.0.0.1:8065"     # EXAMPLE: always loopback; Nginx fronts it
ENABLE_LOCAL_MODE="0"                          # EXAMPLE: "1" if you want operate.sh to drive mmctl --local over SSH (no workstation mmctl needed)
LOCAL_MODE_SOCKET_PATH="/var/tmp/mattermost_local.socket"

# === Remote host (Hetzner / OVH / Contabo / etc.) ===
TARGET_HOST=""                                 # EXAMPLE: "chat.acme.com" or the raw IP if DNS isn't set up yet
TARGET_SSH_USER="deploy"                       # EXAMPLE: "root" for the first provision; "deploy" afterwards (provisioner creates that user)
DEPLOY_METHOD="apt"                            # EXAMPLE: "apt" for production, "docker" for staging or Ubuntu 25.10

# === PostgreSQL ===
POSTGRES_DSN="postgres://mmuser:password@localhost:5432/mattermost?sslmode=disable"
# EXAMPLE (local): "postgres://mmuser:STRONGPASSWORD@localhost:5432/mattermost?sslmode=disable"
# EXAMPLE (Supabase session-pooler, NOT transaction pooler): "postgres://postgres.PROJ:STRONGPASS@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"
SMOKE_DATABASE_URL=""                          # EXAMPLE: "${POSTGRES_DSN}" — usually same as POSTGRES_DSN
DATABASE_URL=""                                # EXAMPLE: alias some tooling expects
STAGING_DATABASE_URL=""                        # EXAMPLE: separate DSN for the staging box; required for staging rehearsal

# === Nginx ===
NGINX_SITE_PATH="/etc/nginx/sites-available/mattermost.conf"
NGINX_SITE_LINK="/etc/nginx/sites-enabled/mattermost.conf"
NGINX_ENABLE_TLS="0"                           # EXAMPLE: "1" if Cloudflare's orange-cloud is OFF and Nginx must terminate TLS itself
NGINX_CERT_PATH="/etc/nginx/ssl/origin.pem"    # EXAMPLE: path to Cloudflare Origin CA cert (15-year) or Let's Encrypt cert
NGINX_KEY_PATH="/etc/nginx/ssl/origin-key.pem"

# === SMTP (required for password-reset activation — no SMTP = no one can log in) ===
SMTP_SERVER=""                                 # EXAMPLE: "smtp.postmarkapp.com" or "smtp.mailgun.org" or "email-smtp.us-east-1.amazonaws.com"
SMTP_PORT="587"                                # EXAMPLE: "587" (STARTTLS) or "465" (implicit TLS)
SMTP_USERNAME=""                               # EXAMPLE: your Postmark server token, or Mailgun "postmaster@..." address
SMTP_PASSWORD=""                               # EXAMPLE: your provider's SMTP password / API token
SMTP_TEST_EMAIL=""                             # EXAMPLE: "admin@acme.com" — verify-live triggers a password-reset to this address
ALLOW_CORS_ORIGINS=""                          # EXAMPLE: "https://chat.acme.com" — only needed if you front the site from >1 hostname

# === Backups + rollback inputs ===
BACKUP_PATH=""                                 # EXAMPLE: "/var/backups/mattermost/mm_2026-04-15.sql.gz" — pre-cutover PG dump
SCRATCH_DB_URL=""                              # EXAMPLE: "postgres://mmuser:STRONGPASS@localhost:5432/mm_restore_drill?sslmode=disable"
ROLLBACK_DB_BACKUP=""                          # EXAMPLE: same as BACKUP_PATH after you've proven restore drill
ROLLBACK_CONFIG_BACKUP=""                      # EXAMPLE: "/var/backups/mattermost/config_2026-04-15.tgz"
ROLLBACK_CONFIG_TARGET="/opt/mattermost/config"
ROLLBACK_DATA_BACKUP=""                        # EXAMPLE: "/var/backups/mattermost/data_2026-04-15.tgz"
ROLLBACK_DATA_TARGET="/opt/mattermost/data"
ROLLBACK_OWNER=""                              # EXAMPLE: "Jane Admin <jane@acme.com>" — named human, NOT a role; readiness gate blocks if unset

# === MCP wiring (used by scripts/install-mcp-servers.sh) ===
# Leave blank to skip registering the Mattermost MCP server; the Playwright MCP
# is token-less. Create MATTERMOST_ADMIN_TOKEN as a system-admin Personal
# Access Token via System Console -> Integrations -> Personal Access Tokens.
MATTERMOST_ADMIN_TOKEN=""                      # EXAMPLE: "ijkl1234mnop5678qrst9012uvwx" — system_admin PAT

# === Cloudflare edge provisioning (./operate.sh edge) ===
CLOUDFLARE_ENABLED="0"                         # EXAMPLE: "1" to enable; requires CLOUDFLARE_API_TOKEN + CF_ZONE_ID + ORIGIN_SERVER_IP
CLOUDFLARE_MODE="plan"                         # EXAMPLE: "plan" to print, "execute" to actually call the CF API
CLOUDFLARE_API_TOKEN=""                        # EXAMPLE: Zone:Edit token scoped to acme.com (https://dash.cloudflare.com/profile/api-tokens)
CF_ZONE_ID=""                                  # EXAMPLE: "abc123def456..." — find in Cloudflare dashboard, right sidebar of zone overview
ORIGIN_SERVER_IP=""                            # EXAMPLE: "95.217.12.34" — Hetzner-assigned IPv4 of your Mattermost host
CALLS_HOSTNAME=""                              # EXAMPLE: "calls.acme.com" — grey-cloud (DNS-only) record for Mattermost Calls UDP 8443
CALLS_SERVER_IP=""                             # EXAMPLE: usually same as ORIGIN_SERVER_IP
CLOUDFLARE_ORIGIN_HOSTNAMES=""                 # EXAMPLE: "chat.acme.com" — extra hostnames on the origin cert
