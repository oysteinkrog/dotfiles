#!/usr/bin/env python3
"""Regenerate the secrets key list in ~/.claude/CLAUDE.md and ~/.codex/AGENTS.md.

Reads variable names (not values) from ~/.config/secrets/.env and rewrites the
content between `<!-- BEGIN:secrets-keys ... -->` and `<!-- END:secrets-keys -->`
markers. Idempotent; only writes if the rendered block changed.
"""
from __future__ import annotations

import re
import sys
from pathlib import Path

HOME = Path.home()
ENV_FILE = HOME / ".config" / "secrets" / ".env"
TARGETS = [HOME / ".claude" / "CLAUDE.md", HOME / ".codex" / "AGENTS.md"]

BEGIN = re.compile(r"<!-- BEGIN:secrets-keys[^>]*-->")
END = "<!-- END:secrets-keys -->"
KEY_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*(?==)")


def extract_keys(env_path: Path) -> list[str]:
    keys: set[str] = set()
    for raw in env_path.read_text(encoding="utf-8").splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        m = KEY_RE.match(line)
        if m:
            keys.add(m.group(0))
    return sorted(keys)


def render_block(keys: list[str]) -> str:
    inline = ", ".join(f"`{k}`" for k in keys)
    return (
        "<!-- BEGIN:secrets-keys (regenerated by ~/bin/refresh-secrets-list — do not edit by hand) -->\n"
        f"  {inline}.\n"
        f"  {END}"
    )


def update(target: Path, block: str) -> str:
    if not target.exists():
        return "skip (file missing)"
    text = target.read_text(encoding="utf-8")
    m_begin = BEGIN.search(text)
    if not m_begin:
        return "skip (no BEGIN marker)"
    end_idx = text.find(END, m_begin.end())
    if end_idx == -1:
        return "skip (no END marker)"
    end_idx += len(END)
    new_text = text[: m_begin.start()] + block + text[end_idx:]
    if new_text == text:
        return "unchanged"
    target.write_text(new_text, encoding="utf-8")
    return "updated"


def main() -> int:
    if not ENV_FILE.exists():
        print(f"error: {ENV_FILE} does not exist", file=sys.stderr)
        return 1
    keys = extract_keys(ENV_FILE)
    if not keys:
        print(f"error: no KEY=VALUE entries found in {ENV_FILE}", file=sys.stderr)
        return 1
    block = render_block(keys)
    print(f"found {len(keys)} keys in {ENV_FILE.relative_to(HOME).as_posix()}")
    rc = 0
    for target in TARGETS:
        status = update(target, block)
        rel = target.relative_to(HOME).as_posix()
        print(f"  ~/{rel}: {status}")
        if status.startswith("skip"):
            rc = max(rc, 0)  # not an error; just informational
    return rc


if __name__ == "__main__":
    sys.exit(main())
