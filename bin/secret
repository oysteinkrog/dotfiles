#!/usr/bin/env bash
# secret — read one secret from ~/.config/secrets/.env (single source of truth).
#
# Usage:
#   secret KEY       print the value to stdout
#   secret --list    list available keys (no values)
#
# Shell-agnostic replacement for the former fish-only function; works from
# bash, fish, scripts, cron, anything on PATH. Never source the .env file
# into a shell: fetch only the key you need, at the moment you need it.
set -euo pipefail

env_file="${SECRETS_ENV_FILE:-$HOME/.config/secrets/.env}"

if [ "${1:-}" = --list ]; then
    awk -F= '/^[A-Za-z_][A-Za-z0-9_]*=/ {print $1}' "$env_file" | sort -u
    exit 0
fi

if [ $# -ne 1 ]; then
    echo "usage: secret KEY  |  secret --list" >&2
    exit 2
fi

if [ ! -f "$env_file" ]; then
    echo "secret: $env_file not found" >&2
    exit 1
fi

val=$(awk -F= -v k="$1" '$1==k {sub(/^[^=]+=/,""); print; exit}' "$env_file")
if [ -z "$val" ]; then
    echo "secret: $1 not found in $env_file" >&2
    exit 1
fi
printf '%s\n' "$val"
