#!/usr/bin/env bash
# with-secrets — run a command with named secrets in its environment.
#
# Usage:
#   with-secrets KEY [KEY ...] -- CMD [ARGS ...]
#
# Each KEY is fetched from ~/.config/secrets/.env via `secret` and exported
# only into CMD's environment. Because CMD is exec'd from this short-lived
# process, the variables vanish when CMD exits: nothing leaks into the
# calling shell. Shell-agnostic replacement for the former fish-only
# function (one behavior change: CMD must be a real command on PATH or a
# path, not a shell function of the calling shell).
set -euo pipefail

usage() { echo "usage: with-secrets KEY [KEY ...] -- CMD [ARGS ...]" >&2; exit 2; }

# Resolve the sibling `secret` helper; fall back to PATH.
secret_bin="$(dirname "$0")/secret"
[ -x "$secret_bin" ] || secret_bin="secret"

keys=()
while [ $# -gt 0 ] && [ "$1" != -- ]; do
    keys+=("$1")
    shift
done

[ "${1:-}" = -- ] || usage
shift  # drop the literal --
[ $# -ge 1 ] || usage
if [ ${#keys[@]} -eq 0 ]; then
    echo "with-secrets: no keys given before --" >&2
    exit 2
fi

for k in "${keys[@]}"; do
    val="$("$secret_bin" "$k")"   # aborts (set -e) with secret's error if missing
    export "$k=$val"
done

exec "$@"
