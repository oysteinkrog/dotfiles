#!/usr/bin/env python3
"""xt — fetch and display X/Twitter tweets and articles by URL or ID.

Uses the public syndication API (no auth required for public tweets).
Falls back to authenticated API using cookies from ft's env file.
For X Articles, uses the authenticated GraphQL API to fetch full content.

Usage:
    xt <tweet-url-or-id>           # human-readable output
    xt -j <tweet-url-or-id>        # JSON output
    xt -d <tweet-url-or-id>        # download images to /tmp/xt/
    xt -r <tweet-url-or-id>        # raw API JSON (unprocessed)
    xt <article-url>               # fetch article body (x.com/i/article/...)
"""

import argparse
import json
import os
import re
import sys
import textwrap
import urllib.request
import urllib.error
import urllib.parse
from pathlib import Path


SYNDICATION_URL = "https://cdn.syndication.twimg.com/tweet-result?id={tweet_id}&lang=en&token=x"
GRAPHQL_TWEET_URL = "https://x.com/i/api/graphql/tmhPpO5sDermwYmq3h034A/TweetResultByRestId"
BEARER_TOKEN = "AAAAAAAAAAAAAAAAAAAAANRILgAAAAAAnNwIzUejRCOuH5E6I8xnZz4puTs%3D1Zv7ttfk8LF81IUq16cHjhLTvJu4FA33AGWWjCpTnA"
COOKIES_ENV = Path.home() / ".." / ".." / "c" / "work" / "life" / "data" / "x-cookies.env"
# Also try direct path
COOKIES_ENV_ALT = Path("/c/work/life/data/x-cookies.env")


def extract_tweet_id(arg: str) -> str | None:
    """Extract tweet ID from a URL or bare ID."""
    # Bare numeric ID
    if re.match(r"^\d+$", arg):
        return arg
    # URL patterns: x.com, twitter.com, mobile.twitter.com, etc.
    m = re.search(r"(?:twitter\.com|x\.com)/\w+/status(?:es)?/(\d+)", arg)
    if m:
        return m.group(1)
    return None


def extract_article_id(arg: str) -> str | None:
    """Extract article ID from an X article URL."""
    m = re.search(r"(?:twitter\.com|x\.com)/i/article/(\d+)", arg)
    if m:
        return m.group(1)
    return None


def load_cookies() -> tuple[str, str] | None:
    """Load ct0 and auth_token from cookies env file."""
    for path in [COOKIES_ENV, COOKIES_ENV_ALT]:
        if path.exists():
            ct0 = auth = None
            for line in path.read_text().splitlines():
                line = line.strip()
                if line.startswith("#") or "=" not in line:
                    continue
                k, v = line.split("=", 1)
                if k.strip() == "FT_CT0":
                    ct0 = v.strip()
                elif k.strip() == "FT_AUTH_TOKEN":
                    auth = v.strip()
            if ct0 and auth:
                return ct0, auth
    return None


def fetch_article_content(tweet_id: str) -> dict | None:
    """Fetch article body via authenticated GraphQL API.

    Returns dict with 'title', 'plain_text', 'preview_text' or None if
    the tweet has no article or auth is unavailable.
    """
    creds = load_cookies()
    if not creds:
        return None
    ct0, auth_token = creds

    variables = json.dumps({
        "tweetId": tweet_id,
        "withCommunity": False,
        "includePromotedContent": False,
        "withVoice": False,
    })
    features = json.dumps({
        "rweb_video_screen_enabled": True,
        "articles_preview_enabled": True,
        "responsive_web_twitter_article_tweet_consumption_enabled": True,
        "longform_notetweets_rich_text_read_enabled": True,
        "longform_notetweets_inline_media_enabled": True,
        "responsive_web_enhance_cards_enabled": True,
        "responsive_web_graphql_timeline_navigation_enabled": True,
        "responsive_web_graphql_skip_user_profile_image_extensions_enabled": False,
        "creator_subscriptions_tweet_preview_api_enabled": True,
        "communities_web_enable_tweet_community_results_fetch": True,
        "c9s_tweet_anatomy_moderator_badge_enabled": True,
        "content_disclosure_indicator_enabled": True,
        "content_disclosure_ai_generated_indicator_enabled": True,
        "graphql_is_translatable_rweb_tweet_is_translatable_enabled": True,
        "view_counts_everywhere_api_enabled": True,
        "longform_notetweets_consumption_enabled": True,
        "tweet_with_visibility_results_prefer_gql_limited_actions_policy_enabled": True,
        "freedom_of_speech_not_reach_fetch_enabled": True,
        "standardized_nudges_misinfo": True,
        "responsive_web_edit_tweet_api_enabled": True,
        "verified_phone_label_enabled": False,
    })
    field_toggles = json.dumps({
        "withArticleRichContentState": True,
        "withArticlePlainText": True,
    })

    params = urllib.parse.urlencode({
        "variables": variables,
        "features": features,
        "fieldToggles": field_toggles,
    })
    url = f"{GRAPHQL_TWEET_URL}?{params}"

    req = urllib.request.Request(url, headers={
        "Authorization": f"Bearer {urllib.parse.unquote(BEARER_TOKEN)}",
        "X-Csrf-Token": ct0,
        "Cookie": f"ct0={ct0}; auth_token={auth_token}",
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
    })
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            data = json.loads(resp.read().decode())
        result = data.get("data", {}).get("tweetResult", {}).get("result", {})
        article = result.get("article", {}).get("article_results", {}).get("result")
        if article and article.get("plain_text"):
            return {
                "title": article.get("title", ""),
                "plain_text": article.get("plain_text", ""),
                "preview_text": article.get("preview_text", ""),
            }
    except Exception as e:
        print(f"Warning: failed to fetch article content: {e}", file=sys.stderr)
    return None


GRAPHQL_USER_ARTICLES_URL = "https://x.com/i/api/graphql/XznGU9VNo0ji6vdFWmUhlQ/UserArticlesTweets"
GRAPHQL_USER_BY_SCREEN_NAME_URL = "https://x.com/i/api/graphql/IGgvgiOx4QZndDHuD3x9TQ/UserByScreenName"


def lookup_user_id(screen_name: str) -> str | None:
    """Look up a user's rest_id by screen name via GraphQL."""
    creds = load_cookies()
    if not creds:
        return None
    ct0, auth_token = creds

    variables = json.dumps({"screen_name": screen_name, "withSafetyModeUserFields": True})
    features = json.dumps({
        "hidden_profile_subscriptions_enabled": True,
        "rweb_tipjar_consumption_enabled": True,
        "responsive_web_graphql_exclude_directive_enabled": True,
        "verified_phone_label_enabled": False,
        "responsive_web_graphql_skip_user_profile_image_extensions_enabled": False,
        "responsive_web_graphql_timeline_navigation_enabled": True,
    })
    params = urllib.parse.urlencode({"variables": variables, "features": features})
    req = urllib.request.Request(f"{GRAPHQL_USER_BY_SCREEN_NAME_URL}?{params}", headers={
        "Authorization": f"Bearer {urllib.parse.unquote(BEARER_TOKEN)}",
        "X-Csrf-Token": ct0,
        "Cookie": f"ct0={ct0}; auth_token={auth_token}",
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
    })
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            data = json.loads(resp.read().decode())
        return data.get("data", {}).get("user", {}).get("result", {}).get("rest_id")
    except Exception:
        return None


def find_article_in_user_tweets(user_id: str, article_id: str) -> tuple[str, dict] | None:
    """Search a user's article tweets for a specific article ID.

    Returns (tweet_id, article_dict) or None.
    """
    creds = load_cookies()
    if not creds:
        return None
    ct0, auth_token = creds

    variables = json.dumps({
        "userId": user_id,
        "count": 20,
        "includePromotedContent": False,
        "withVoice": False,
    })
    features = json.dumps({
        "rweb_video_screen_enabled": True,
        "articles_preview_enabled": True,
        "responsive_web_twitter_article_tweet_consumption_enabled": True,
        "longform_notetweets_rich_text_read_enabled": True,
        "longform_notetweets_inline_media_enabled": True,
        "responsive_web_enhance_cards_enabled": True,
        "responsive_web_graphql_timeline_navigation_enabled": True,
        "responsive_web_graphql_skip_user_profile_image_extensions_enabled": False,
        "creator_subscriptions_tweet_preview_api_enabled": True,
        "communities_web_enable_tweet_community_results_fetch": True,
        "c9s_tweet_anatomy_moderator_badge_enabled": True,
        "content_disclosure_indicator_enabled": True,
        "content_disclosure_ai_generated_indicator_enabled": True,
        "graphql_is_translatable_rweb_tweet_is_translatable_enabled": True,
        "view_counts_everywhere_api_enabled": True,
        "longform_notetweets_consumption_enabled": True,
        "tweet_with_visibility_results_prefer_gql_limited_actions_policy_enabled": True,
        "freedom_of_speech_not_reach_fetch_enabled": True,
        "standardized_nudges_misinfo": True,
        "responsive_web_edit_tweet_api_enabled": True,
        "verified_phone_label_enabled": False,
        "profile_label_improvements_pcf_label_in_post_enabled": True,
        "rweb_tipjar_consumption_enabled": True,
    })
    field_toggles = json.dumps({
        "withArticleRichContentState": True,
        "withArticlePlainText": True,
    })

    params = urllib.parse.urlencode({
        "variables": variables,
        "features": features,
        "fieldToggles": field_toggles,
    })
    req = urllib.request.Request(f"{GRAPHQL_USER_ARTICLES_URL}?{params}", headers={
        "Authorization": f"Bearer {urllib.parse.unquote(BEARER_TOKEN)}",
        "X-Csrf-Token": ct0,
        "Cookie": f"ct0={ct0}; auth_token={auth_token}",
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
    })
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            data = json.loads(resp.read().decode())
    except Exception as e:
        print(f"Warning: failed to fetch user articles: {e}", file=sys.stderr)
        return None

    # Walk the response tree to find tweet+article pairs
    def find_tweets(obj, results=None):
        if results is None:
            results = []
        if isinstance(obj, dict):
            if "rest_id" in obj and "article" in obj:
                art = obj["article"].get("article_results", {}).get("result", {})
                if art.get("rest_id") == article_id:
                    results.append((obj["rest_id"], {
                        "title": art.get("title", ""),
                        "plain_text": art.get("plain_text", ""),
                        "preview_text": art.get("preview_text", ""),
                    }))
            for v in obj.values():
                find_tweets(v, results)
        elif isinstance(obj, list):
            for v in obj:
                find_tweets(v, results)
        return results

    matches = find_tweets(data)
    return matches[0] if matches else None


def fetch_tweet(tweet_id: str) -> dict:
    """Fetch tweet data from syndication API."""
    url = SYNDICATION_URL.format(tweet_id=tweet_id)
    req = urllib.request.Request(url, headers={
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
        "Accept": "application/json",
    })
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            return json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        if e.code == 404:
            print(f"Error: Tweet {tweet_id} not found (404)", file=sys.stderr)
        elif e.code == 403:
            print(f"Error: Tweet {tweet_id} is protected or unavailable (403)", file=sys.stderr)
        else:
            print(f"Error: HTTP {e.code} fetching tweet {tweet_id}", file=sys.stderr)
        sys.exit(1)


def extract_text(data: dict) -> str:
    """Get clean tweet text, expanding t.co links."""
    text = data.get("text", "")
    # Replace t.co URLs with expanded versions
    for url_entity in data.get("entities", {}).get("urls", []):
        text = text.replace(url_entity.get("url", ""), url_entity.get("expanded_url", ""))
    # Remove pic.twitter.com / pic.x.com media links
    for media in data.get("entities", {}).get("media", []):
        text = text.replace(media.get("url", ""), "").strip()
    return text.strip()


def get_media(data: dict) -> list[dict]:
    """Extract media items (images, videos)."""
    items = []
    for m in data.get("mediaDetails", []):
        item = {
            "type": m.get("type", "photo"),
            "url": m.get("media_url_https", ""),
        }
        # Video: get best quality variant
        if m.get("type") == "video" and m.get("video_info", {}).get("variants"):
            variants = [v for v in m["video_info"]["variants"] if v.get("bitrate")]
            if variants:
                best = max(variants, key=lambda v: v.get("bitrate", 0))
                item["video_url"] = best["url"]
        items.append(item)
    return items


def get_quoted_tweet(data: dict) -> dict | None:
    """Extract quoted tweet if present."""
    qt = data.get("quoted_tweet")
    if qt:
        return {
            "author": qt.get("user", {}).get("name", ""),
            "handle": qt.get("user", {}).get("screen_name", ""),
            "text": extract_text(qt),
        }
    return None


def download_images(data: dict, tweet_id: str) -> list[str]:
    """Download images to /tmp/xt/ and return file paths."""
    media = get_media(data)
    if not media:
        return []
    outdir = Path("/tmp/xt")
    outdir.mkdir(parents=True, exist_ok=True)
    paths = []
    for i, m in enumerate(media):
        url = m["url"]
        if not url:
            continue
        # Get best quality for images
        if m["type"] == "photo":
            url = url + "?format=jpg&name=large"
        ext = ".jpg" if m["type"] == "photo" else ".mp4"
        fname = f"{tweet_id}_{i}{ext}"
        fpath = outdir / fname
        try:
            req = urllib.request.Request(url, headers={
                "User-Agent": "Mozilla/5.0",
            })
            with urllib.request.urlopen(req, timeout=30) as resp:
                fpath.write_bytes(resp.read())
            paths.append(str(fpath))
        except Exception as e:
            print(f"Warning: failed to download {url}: {e}", file=sys.stderr)
    return paths


def format_human(data: dict, downloaded: list[str] | None = None,
                  article: dict | None = None) -> str:
    """Format tweet for human reading."""
    user = data.get("user", {})
    author = user.get("name", "Unknown")
    handle = user.get("screen_name", "unknown")
    created = data.get("created_at", "")
    likes = data.get("favorite_count", 0)
    text = extract_text(data)
    media = get_media(data)
    quoted = get_quoted_tweet(data)
    tweet_id = data.get("id_str", "")

    lines = []
    lines.append(f"\033[1m{author}\033[0m \033[2m@{handle}\033[0m")
    lines.append(f"\033[2m{created}\033[0m")
    lines.append("")

    # If article content is available, show it instead of the bare link
    if article:
        title = article.get("title", "")
        if title:
            lines.append(f"\033[1m{title}\033[0m")
            lines.append("")
        for paragraph in article["plain_text"].split("\n"):
            if paragraph.strip():
                lines.extend(textwrap.wrap(paragraph, width=80))
            else:
                lines.append("")
        lines.append("")
    else:
        # Wrap text at 80 chars
        for paragraph in text.split("\n"):
            if paragraph.strip():
                lines.extend(textwrap.wrap(paragraph, width=80))
            else:
                lines.append("")
        lines.append("")

    if quoted:
        lines.append(f"  \033[2m┃ \033[1m{quoted['author']}\033[0m \033[2m@{quoted['handle']}\033[0m")
        for qline in textwrap.wrap(quoted["text"], width=74):
            lines.append(f"  \033[2m┃\033[0m {qline}")
        lines.append("")

    if media:
        for i, m in enumerate(media):
            label = "Image" if m["type"] == "photo" else "Video"
            lines.append(f"  [{label}] {m['url']}")
            if m.get("video_url"):
                lines.append(f"          {m['video_url']}")
        lines.append("")

    if downloaded:
        lines.append("  Downloaded:")
        for p in downloaded:
            lines.append(f"    {p}")
        lines.append("")

    lines.append(f"\033[2m♥ {likes:,}  •  https://x.com/{handle}/status/{tweet_id}\033[0m")
    return "\n".join(lines)


def format_json(data: dict, article: dict | None = None) -> dict:
    """Structured JSON output."""
    user = data.get("user", {})
    media = get_media(data)
    quoted = get_quoted_tweet(data)
    out = {
        "id": data.get("id_str", ""),
        "author": user.get("name", ""),
        "handle": user.get("screen_name", ""),
        "created_at": data.get("created_at", ""),
        "text": extract_text(data),
        "likes": data.get("favorite_count", 0),
        "lang": data.get("lang", ""),
        "url": f"https://x.com/{user.get('screen_name', '')}/status/{data.get('id_str', '')}",
        "media": media,
        "quoted_tweet": quoted,
        "links": [u["expanded_url"] for u in data.get("entities", {}).get("urls", [])],
    }
    if article:
        out["article"] = article
    return out


def main():
    parser = argparse.ArgumentParser(
        description="Fetch and display X/Twitter tweets and articles",
        usage="xt [-j|-r|-d] <tweet-url-or-id-or-article-url>",
    )
    parser.add_argument("tweet", help="Tweet URL, numeric ID, or article URL")
    parser.add_argument("-j", "--json", action="store_true", help="JSON output")
    parser.add_argument("-r", "--raw", action="store_true", help="Raw API JSON")
    parser.add_argument("-d", "--download", action="store_true", help="Download images to /tmp/xt/")
    parser.add_argument("-a", "--author", help="Author handle for article URL lookup (e.g. intuitiveml)")
    args = parser.parse_args()

    # Check if this is an article URL (x.com/i/article/<id>)
    article_id = extract_article_id(args.tweet)
    article = None

    if article_id:
        # For article URLs, we need the author to look up their article tweets
        author = args.author
        if not author:
            print("Error: article URLs require --author <handle> to look up the tweet.", file=sys.stderr)
            print(f"  Example: xt -a intuitiveml '{args.tweet}'", file=sys.stderr)
            print(f"  Tip: use the tweet URL instead (x.com/<user>/status/<id>)", file=sys.stderr)
            sys.exit(1)
        user_id = lookup_user_id(author)
        if not user_id:
            print(f"Error: couldn't find user @{author}", file=sys.stderr)
            sys.exit(1)
        result = find_article_in_user_tweets(user_id, article_id)
        if not result:
            print(f"Error: couldn't find article {article_id} in @{author}'s articles", file=sys.stderr)
            sys.exit(1)
        tweet_id, article = result
    else:
        tweet_id = extract_tweet_id(args.tweet)

    if not tweet_id:
        print(f"Error: couldn't extract tweet or article ID from: {args.tweet}", file=sys.stderr)
        sys.exit(1)

    data = fetch_tweet(tweet_id)

    if args.raw:
        print(json.dumps(data, indent=2, ensure_ascii=False))
        return

    # Auto-fetch article content if the tweet contains an article
    if not article and (data.get("article") or article_id):
        article = fetch_article_content(tweet_id)

    downloaded = None
    if args.download:
        downloaded = download_images(data, tweet_id)

    if args.json:
        out = format_json(data, article)
        if downloaded:
            out["downloaded_files"] = downloaded
        print(json.dumps(out, indent=2, ensure_ascii=False))
    else:
        print(format_human(data, downloaded, article))


if __name__ == "__main__":
    main()
