# Large binaries (install via package manager)
bin/hugo
bin/dcg

# Claude Code temp/scratch files
.claude/analyze_frame.py
.claude/plan.md
.claude/backups/
.claude/output/
.claude/mcp-needs-auth-cache.json
.claude/sessions/
.claude/*.bak
.config/fish/functions/*.bak

# Large binaries (>10MB; install/build locally instead of tracking)
bin/cass.exe
bin/cass-old.exe
bin/cm.exe
bin/ms.exe
bin/claude-rs
bin/claurst
bin/claw
bin/codedb

# Claude Code runtime state and machine-local config
.claude/.last-cleanup
.claude/policy-limits.json
.claude/remote-settings.json

# Skills installed via jsm (jeffreys-skills.md) — re-install via `jsm sync`,
# don't track. Marker file at the dir root.
.claude/skills/.SKILLS_MANAGED_BY_JSM
.claude/skills/cursor/
.claude/skills/de-slopify/
.claude/skills/dsr/
.claude/skills/gcloud/
.claude/skills/repeatedly-apply-skill/
.claude/skills/rust-crates-publishing/

# fish 4.3 migration files (machine-local; regenerated on upgrade)
.config/fish/conf.d/fish_frozen_*.fish

# External skill clones (third-party repos cloned into .claude/skills/).
# Promote to a submodule (.gitmodules) if you want to track the pointer.
.claude/skills/cc-slidev/
.claude/skills/frontend-slides/

# Misc
list-worktrees.sh
