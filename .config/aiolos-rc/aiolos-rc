#!/usr/bin/env bash
# aiolos-rc — launch Claude Code so that:
#   * remote-control / sessions register under your MAIN claude.ai login
#     (so the session shows up in your main account on phone/web), while
#   * inference (/v1/messages) runs through aiolos (load-balanced, or pinned).
#
# How: Claude runs in its NORMAL mode with base URL pinned to api.anthropic.com
# (Claude's RC gate requires that host), so remote control stays enabled. A
# per-process LD_PRELOAD redirects ONLY this process's connections to
# api.anthropic.com to a local TLS shim (trusted via NODE_EXTRA_CA_CERTS), which
# splits traffic by path:
#   /v1/messages* -> aiolos ;  everything else -> Anthropic (your main login).
# ~/.claude/settings.local.json pins the base URL to the aiolos proxy for normal
# use; we override it for THIS process only with `--settings` (flagSettings, which
# outranks it) so the host stays api.anthropic.com. No shared file is mutated.
#
# We deliberately do NOT use ANTHROPIC_UNIX_SOCKET: setting it flips Claude into
# "host-managed auth" mode, which breaks the remote-control subscription check.
#
# ONE SHIM PER SESSION: every invocation starts its own shim on a fresh ephemeral
# port and tears it down when Claude exits. Multiple concurrent Claude instances
# are fully isolated — no shared port, no cross-session restarts, no single point
# of failure.
#
# Routing modes:
#   no-pin (--no-pin)          inference -> aiolos with NO account header; aiolos
#                              load-balances across all accounts (daily driver;
#                              used by the c/cc/cr wrappers).
#   pinned (default/--account) inference pinned strictly to one account; fails
#                              closed (503) if that account is paused/limited.
#
# Machine-local secrets/config live OUTSIDE this (tracked, public) dir, under
#   ~/.config/secrets/aiolos-rc/  (override with AIOLOS_RC_SECRETS):
#     certs/       local api.anthropic.com CA + leaf (generated by setup.sh)
#     config.env   DEFAULT_ACCOUNT=<aiolos account id>   (for pinned mode)
# Run ./setup.sh once on a new machine to build preload.so and generate certs.
#
# Usage:
#   aiolos-rc [--no-pin | --account <id|email>] [claude args...]
#   aiolos-rc --no-pin -c                       # continue, load-balanced
#   aiolos-rc --stop | --status                 # manage running session shims
#
# Env: RC_DEBUG=1 logs per-request routing (per-session log under shims/).
# The aiolos base URL is read from ANTHROPIC_BASE_URL, else ~/.claude/settings.local.json.
set -euo pipefail

DIR="$HOME/.config/aiolos-rc"                                   # code (symlinked into dotfiles)
SECRETS="${AIOLOS_RC_SECRETS:-$HOME/.config/secrets/aiolos-rc}" # certs + config.env (never tracked)
CA="$SECRETS/certs/ca.pem"
CERT="$SECRETS/certs/leaf-chain.pem"
KEY="$SECRETS/certs/leaf.key"
PRELOAD="$DIR/preload.so"
SHIMS_DIR="$DIR/shims"      # one registry file per running session shim (named by PID)
mkdir -p "$SHIMS_DIR"

# Machine-local defaults (account id for pinned mode). Never committed.
DEFAULT_ACCOUNT=""
[ -f "$SECRETS/config.env" ] && . "$SECRETS/config.env"

pid_alive() { kill -0 "$1" 2>/dev/null; }
# True only if $1 is alive AND is actually one of our shim processes — guards
# --stop/--status against a recycled PID now owned by an unrelated process.
is_our_shim() {
  pid_alive "$1" || return 1
  [ -r "/proc/$1/cmdline" ] || return 1
  tr '\0' ' ' < "/proc/$1/cmdline" | grep -q 'aiolos-rc/shim\.py'
}

# --stop / --status operate on ALL running session shims.
case "${1:-}" in
  --stop)
    n=0
    for f in "$SHIMS_DIR"/*; do
      [ -e "$f" ] || continue
      case "$f" in *.log) continue ;; esac
      pid="$(basename "$f")"
      if is_our_shim "$pid"; then kill "$pid" 2>/dev/null || true; n=$((n+1)); fi
      rm -f "$f" "$f.log"
    done
    echo "aiolos-rc: stopped $n session shim(s)"
    exit 0 ;;
  --status)
    any=0
    for f in "$SHIMS_DIR"/*; do
      [ -e "$f" ] || continue
      case "$f" in *.log) continue ;; esac
      pid="$(basename "$f")"
      if is_our_shim "$pid"; then echo "aiolos-rc: $(cat "$f")"; any=1
      else rm -f "$f" "$f.log"; fi
    done
    [ "$any" = 1 ] || echo "aiolos-rc: no session shims running"
    exit 0 ;;
esac

# Preflight: the shim needs the local certs; point the user at setup.sh if absent.
if [ ! -f "$CERT" ] || [ ! -f "$KEY" ] || [ ! -f "$CA" ]; then
  echo "aiolos-rc: certs missing under $SECRETS/certs — run $DIR/setup.sh first" >&2
  exit 1
fi
if [ ! -f "$PRELOAD" ]; then
  echo "aiolos-rc: $PRELOAD not built — run $DIR/setup.sh first" >&2
  exit 1
fi

# Routing mode + optional leading options.
NOPIN=0
ACCOUNT="${RC_ACCOUNT_ID:-$DEFAULT_ACCOUNT}"
while true; do
  case "${1:-}" in
    --no-pin)  NOPIN=1; ACCOUNT=""; shift ;;
    --account) ACCOUNT="$2"; NOPIN=0; shift 2 ;;
    *) break ;;
  esac
done

# The aiolos URL for the inference leg. Prefer an explicit shell override; else
# read it from ~/.claude/settings.local.json (the on-disk source of record).
AIOLOS_URL="${ANTHROPIC_BASE_URL:-}"
if [ -z "$AIOLOS_URL" ]; then
  AIOLOS_URL="$(python3 -c "import json,sys
try:
    d=json.load(open('$HOME/.claude/settings.local.json'))
    print(d.get('env',{}).get('ANTHROPIC_BASE_URL',''))
except Exception:
    print('')")"
fi
[ -n "$AIOLOS_URL" ] || { echo "aiolos-rc: no aiolos URL found (set ANTHROPIC_BASE_URL or add it to ~/.claude/settings.local.json env)"; exit 1; }

# Pinned mode needs an account. Load-balanced (--no-pin) does not.
if [ "$NOPIN" = 0 ] && [ -z "$ACCOUNT" ]; then
  echo "aiolos-rc: no account for pinned mode. Set DEFAULT_ACCOUNT in $SECRETS/config.env, or pass --account <id|email>, or use --no-pin." >&2
  exit 1
fi

# Resolve an email to an account id via aiolos, for ergonomics (pinned mode only).
if [ "$NOPIN" = 0 ] && [[ "$ACCOUNT" == *@* ]]; then
  TOK="$(python3 -c "import json;print(json.load(open('$HOME/.claude/.credentials.json'))['claudeAiOauth']['accessToken'])")"
  RESOLVED="$(curl -s --max-time 15 -H "Authorization: Bearer $TOK" "$AIOLOS_URL/api/accounts" \
    | python3 -c "import sys,json
want='$ACCOUNT'
d=json.load(sys.stdin); accts=d if isinstance(d,list) else d.get('accounts',[])
print(next((a['id'] for a in accts if a.get('name')==want), ''))")"
  [ -n "$RESOLVED" ] || { echo "aiolos-rc: no account matching '$ACCOUNT'"; exit 1; }
  ACCOUNT="$RESOLVED"
fi
if [ "$NOPIN" = 1 ]; then MODE="load-balanced"; else MODE="pinned:$ACCOUNT"; fi

# Start THIS session's shim on an ephemeral port (RC_PORT=0). The shim writes the
# port it actually bound to PORTFILE; we read it back and point this process's
# preload at it. Torn down on exit by the trap below.
SHIM_PID=""
PORTFILE="$(mktemp "${TMPDIR:-/tmp}/aiolos-rc-port.XXXXXX")"
# Per-session --settings override (flagSettings). Per-session (not a shared file in
# the code dir) so concurrent instances never share or race on it; removed on exit.
# Give it a .json name (mktemp, then rename) to match a settings file.
_ov_tmp="$(mktemp "${TMPDIR:-/tmp}/aiolos-rc-settings.XXXXXX")"
OVERRIDE_SETTINGS="$_ov_tmp.json"
mv "$_ov_tmp" "$OVERRIDE_SETTINGS"
cleanup() {
  if [ -n "$SHIM_PID" ] && pid_alive "$SHIM_PID"; then kill "$SHIM_PID" 2>/dev/null || true; fi
  [ -n "$SHIM_PID" ] && rm -f "$SHIMS_DIR/$SHIM_PID" "$SHIMS_DIR/$SHIM_PID.log"
  rm -f "$PORTFILE" "$OVERRIDE_SETTINGS"
}
trap cleanup EXIT INT TERM

# Log to a launcher-PID-unique name ($$ differs per concurrent launch), then
# rename to the shim's PID once known. Both end in .log so --status/--stop skip them.
STARTLOG="$SHIMS_DIR/starting.$$.log"
setsid env RC_PORT=0 RC_PORTFILE="$PORTFILE" RC_CERT="$CERT" RC_KEY="$KEY" \
  RC_AIOLOS_URL="$AIOLOS_URL" RC_ACCOUNT_ID="$ACCOUNT" ${RC_DEBUG:+RC_DEBUG="$RC_DEBUG"} \
  python3 "$DIR/shim.py" >"$STARTLOG" 2>&1 &
SHIM_PID=$!
mv -f "$STARTLOG" "$SHIMS_DIR/$SHIM_PID.log" 2>/dev/null || true

# Wait for the shim to report its bound port.
PORT=""
for _ in $(seq 1 100); do
  if [ -s "$PORTFILE" ]; then PORT="$(cat "$PORTFILE")"; break; fi
  pid_alive "$SHIM_PID" || break
  sleep 0.05
done
if [ -z "$PORT" ]; then
  echo "aiolos-rc: shim failed to start; see $SHIMS_DIR/$SHIM_PID.log"
  [ -f "$SHIMS_DIR/$SHIM_PID.log" ] && cat "$SHIMS_DIR/$SHIM_PID.log"
  exit 1
fi
printf 'pid=%s port=%s mode=%s\n' "$SHIM_PID" "$PORT" "$MODE" > "$SHIMS_DIR/$SHIM_PID"
if [ "$NOPIN" = 1 ]; then
  echo "aiolos-rc: inference -> aiolos (load-balanced) ; remote-control -> main login (shim :$PORT)"
else
  echo "aiolos-rc: inference -> account $ACCOUNT (strict) ; remote-control -> main login (shim :$PORT)"
fi

# Keep Claude in NORMAL mode so remote-control stays enabled. Its RC gate (YGn)
# requires the effective base-URL host to be api.anthropic.com, but
# ~/.claude/settings.local.json pins it to the aiolos proxy host for normal use.
# Override it for THIS process only via a `--settings` file (flagSettings, which
# outranks user/project/local settings so its ANTHROPIC_BASE_URL wins WITHOUT
# mutating any shared file). Host stays api.anthropic.com; LD_PRELOAD sends that
# host to this session's shim (cert trusted via NODE_EXTRA_CA_CERTS). Drop
# non-login auth sources so Claude uses your stored claude.ai login (needed for RC).
unset ANTHROPIC_API_KEY ANTHROPIC_AUTH_TOKEN CLAUDE_CODE_OAUTH_TOKEN ANTHROPIC_UNIX_SOCKET
export LD_PRELOAD="$PRELOAD"
export AIOLOS_RC_PORT="$PORT"
export NODE_EXTRA_CA_CERTS="$CA"

printf '%s\n' '{"env":{"ANTHROPIC_BASE_URL":"https://api.anthropic.com"}}' > "$OVERRIDE_SETTINGS"

# Launch the native binary the same way ~/.config/fish/functions/claude.fish does
# (WSL1 p_align patch), as a CHILD (not exec) so the trap can tear down this
# session's shim when Claude exits. LD_PRELOAD is inherited by the child.
CLAUDE_BIN="${CLAUDE_BIN:-$HOME/.local/bin/claude}"
REAL="$(realpath "$CLAUDE_BIN")"
SKIP="${AIOLOS_RC_SKIP_PERMISSIONS---dangerously-skip-permissions}"
if command -v claude-wsl-elf-fix >/dev/null 2>&1 && claude-wsl-elf-fix "$REAL" >/dev/null 2>&1; then
  LAUNCH=("$REAL")
elif [ -x /lib64/ld-linux-x86-64.so.2 ]; then
  LAUNCH=(/lib64/ld-linux-x86-64.so.2 "$REAL")
else
  LAUNCH=("$REAL")
fi

set +e
"${LAUNCH[@]}" --settings "$OVERRIDE_SETTINGS" $SKIP "$@"
rc=$?
set -e
exit $rc   # trap cleanup runs on exit and stops this session's shim
