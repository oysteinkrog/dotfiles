# aiolos-rc machine-local config — copy to ~/.config/secrets/aiolos-rc/config.env
# (setup.sh does this for you). Never committed.
#
# Default aiolos account id for PINNED inference mode (bare `aiolos-rc`, or the
# --account default). NOT needed for the c/cc/cr wrappers — they use --no-pin
# (load-balanced across all accounts). Leave empty to require --no-pin/--account.
DEFAULT_ACCOUNT=""
